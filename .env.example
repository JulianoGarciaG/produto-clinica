PORT=3000

# Senha do painel administrativo (recepcao). Troque em producao.
ADMIN_PASSWORD=troque-esta-senha

# Tamanho da media movel (numero de atendimentos concluidos considerados)
MOVING_AVERAGE_N=20

# Tempo medio de atendimento (minutos) usado antes de existir historico suficiente
DEFAULT_SERVICE_TIME_MINUTES=15

# Ciclo de recalculo em minutos (job agendado)
RECALC_CYCLE_MINUTES=5
